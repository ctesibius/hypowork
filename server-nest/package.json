{
  "name": "@hypowork/server-nest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --filter @paperclipai/server run build",
    "pretypecheck": "pnpm --filter @paperclipai/server run build",
    "predev": "pnpm --filter @paperclipai/server run build",
    "predev:once": "pnpm --filter @paperclipai/server run build",
    "build": "pnpm exec tsc -p tsconfig.json",
    "dev": "tsx watch --tsconfig tsconfig.json src/main.ts",
    "dev:once": "tsx --tsconfig tsconfig.json src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:zip-import": "vitest run --config vitest.config.ts test/zip-extract.vitest-spec.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@hypowork/mem0": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@paperclipai/db": "workspace:*",
    "@paperclipai/server": "workspace:*",
    "@paperclipai/shared": "workspace:*",
    "compression": "^1.8.0",
    "dompurify": "^3.3.2",
    "drizzle-orm": "^0.38.4",
    "fflate": "0.8.2",
    "gray-matter": "4.0.3",
    "jsdom": "^28.1.0",
    "multer": "^2.0.2",
    "pg": "8.11.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/jsdom": "^28.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.6.0",
    "@types/pg": "8.11.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
