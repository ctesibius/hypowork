# Database: auto (default) uses DATABASE_URL when set, else embedded Postgres under ~/.paperclip.
# Use `embedded` to force ~/.paperclip even if DATABASE_URL is present (handy when both are in .env).
# Use `postgres` to require an external DB and fail fast if DATABASE_URL is missing.
# PAPERCLIP_DATABASE_MODE=auto

DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
