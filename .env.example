# Database: auto (default) uses DATABASE_URL when set, else embedded Postgres under ~/.paperclip.
# Use `embedded` to force ~/.paperclip even if DATABASE_URL is present (handy when both are in .env).
# Use `postgres` to require an external DB and fail fast if DATABASE_URL is missing.
# PAPERCLIP_DATABASE_MODE=auto

DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false

# Optional: path to the hypowork bundle root `skills/` (contains `paperclip/`, `paperclip-create-agent/`, …).
# Absolute (e.g. /app/skills in Docker) or relative to monorepo root when server/package.json is found (e.g. skills).
# Local dev usually finds skills/ automatically without this.
PAPERCLIP_SKILLS_DIR=skills
# PAPERCLIP_SKILLS_DIR=/app/skills

# Codex (codex_local): set to 1 so Codex skips loading USER-scope skills from ~/.agents/skills (avoids YAML errors from a broken local hub). Does not affect hypowork/skills injection into CODEX_HOME/skills.
# PAPERCLIP_CODEX_ISOLATE_AGENTS_SKILLS=1
