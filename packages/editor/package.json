{
  "name": "plate",
  "private": true,
  "license": "MIT",
  "scripts": {
    "brl": "pnpm g:brl",
    "build": "pnpm g:build",
    "build:watch": "ROARR_LOG=true turbowatch ./tooling/config/turbowatch.config.ts | roarr",
    "deps:check": "npx npm-check-updates@latest --configFileName config/ncurc.yml --workspaces --root --mergeConfig",
    "deps:update": "npx npm-check-updates@latest --configFileName config/ncurc.yml -u --workspaces --root --mergeConfig",
    "dev:webrtc": "PORT=4444 node ./node_modules/y-webrtc/bin/server.js",
    "e2e": "pnpm exec playwright test --config tooling/config/playwright.config.ts",
    "g:Test:Watch": "turbo run test:watch --filter='@platejs/*' --filter='@udecode/*' --filter='@plate/*' --filter='platejs' --filter='depset'",
    "g:brl": "turbo run brl --filter='@platejs/*' --filter='@udecode/*' --filter='@plate/*' --filter='platejs' --filter='depset'",
    "g:build": "turbo run build --filter='@platejs/*' --filter='@udecode/*' --filter='@plate/*' --filter='platejs' --filter='depset'",
    "g:build:watch": "pnpm build:watch",
    "g:changeset": "changeset",
    "g:clean": "turbo run clean --filter='@platejs/*' --filter='@udecode/*' --filter='@plate/*' --filter='platejs' --filter='depset'",
    "g:lint": "turbo run lint --filter='@platejs/*' --filter='@udecode/*' --filter='@plate/*' --filter='platejs' --filter='depset'",
    "g:lint:fix": "turbo lint:fix",
    "g:plate-ui": "cd ${INIT_CWD:-.} && COMPONENTS_REGISTRY_URL=http://localhost:3000 pnpm exec plate-ui",
    "g:release:next": "pnpm build && pnpm changeset publish --tag next",
    "g:test": "turbo run test --filter='@platejs/*' --filter='@udecode/*' --filter='@plate/*' --filter='platejs' --filter='depset'",
    "g:test:cov": "pnpm g:test --coverage",
    "g:test:covw": "pnpm g:test:cov --watch",
    "g:test:covwa": "pnpm g:test:cov --watchAll",
    "g:test:wa": "pnpm g:test -- --watchAll",
    "g:test:watch": "pnpm g:test -- --watch",
    "g:typecheck": "turbo run typecheck --filter='@platejs/*' --filter='@udecode/*' --filter='@plate/*' --filter='platejs' --filter='depset'",
    "g:typecheck:all": "turbo typecheck",
    "gen:package": "pnpm exec plop --plopfile tooling/scripts/plop/plopfile.cjs package",
    "lint": "biome check . && eslint",
    "lint:fix": "biome check . --fix",
    "nuke:node_modules": "rimraf '**/node_modules'",
    "p:brl": "sh tooling/scripts/brl.sh",
    "p:build": "cd ${INIT_CWD:-.} && pnpm p:tsdown",
    "p:build:watch": "cd ${INIT_CWD:-.} && pnpm exec tsdown --config=${PROJECT_CWD:-.}/tooling/config/tsdown.config.ts --log-level warn --watch",
    "p:clean": "cd ${INIT_CWD:-.} && rimraf dist",
    "p:lint": "biome check ${INIT_CWD:-.}",
    "p:lint:fix": "biome check ${INIT_CWD:-.} --fix",
    "p:test": "cd ${INIT_CWD:-.} && bun test",
    "p:tsdown": "cd ${INIT_CWD:-.} && pnpm exec tsdown --config=${PROJECT_CWD:-.}/tooling/config/tsdown.config.ts --log-level warn",
    "p:typecheck": "tsc -p ./tsconfig.json",
    "prepare": "pnpm dlx skiller@latest apply",
    "release": "pnpm build && pnpm changeset publish",
    "test": "pnpm g:test",
    "test:coverage": "pnpm g:test --coverage",
    "test:watch": "pnpm g:test:watch",
    "translate": "ts-node tooling/scripts/translate.mjs",
    "typecheck": "pnpm g:typecheck",
    "typecheck:all": "pnpm g:typecheck:all",
    "verify": "turbo typecheck test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.6",
    "@changesets/cli": "2.29.7",
    "@changesets/get-github-info": "0.6.0",
    "@happy-dom/global-registrator": "20.0.10",
    "@playwright/test": "1.53.0",
    "@roarr/cli": "5.12.4",
    "@rollup/plugin-babel": "6.1.0",
    "@swc/core": "1.12.0",
    "@tailwindcss/postcss": "4.1.8",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/bun": "1.3.2",
    "@types/is-hotkey": "0.1.10",
    "@types/jest": "29.5.14",
    "@types/lodash": "4.17.17",
    "@types/node": "24.0.0",
    "@types/prismjs": "1.26.5",
    "@types/prompts": "2.4.9",
    "@types/raf": "3.4.3",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/validator": "13.15.1",
    "@typescript-eslint/parser": "^8.47.0",
    "app-root-path": "3.1.0",
    "autoprefixer": "10.4.21",
    "babel-plugin-react-compiler": "1.0.0",
    "barrelsby": "2.8.1",
    "bun": "1.2.13",
    "bun-types": "1.2.13",
    "commander": "14.0.1",
    "concurrently": "9.1.2",
    "cross-env": "7.0.3",
    "dotenv": "16.5.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "openai": "5.3.0",
    "prompts": "2.4.2",
    "react": "19.2.3",
    "react-dnd-test-backend": "16.0.1",
    "react-dom": "19.2.3",
    "rimraf": "6.0.1",
    "slate-test-utils": "1.3.2",
    "tailwindcss": "4.1.8",
    "tinyglobby": "0.2.14",
    "tsdown": "0.16.6",
    "turbo": "2.6.1",
    "turbowatch": "2.29.4",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.47.0",
    "ultracite": "6.3.4",
    "zod": "4.1.12"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.12.0",
    "pnpm": ">=9.0.0"
  }
}
