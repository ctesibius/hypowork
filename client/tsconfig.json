{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/registry-hooks/*": ["./src/plate-markdown/registry-hooks/*"],
      "@/registry-lib/*": ["./src/plate-markdown/registry-lib/*"],
      "@/*": ["./src/*"],
      "@plate-md/*": ["./src/plate-markdown/*"]
    }
  },
  "include": ["src"]
}
