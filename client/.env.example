# Client (Vite) — copy to `.env.local` in this folder for `pnpm dev:client`

# Dev-only: on load, call the server once to ensure project “Factory playground (dev)” + seeded factory rows;
# it appears in the Projects list like any other project (same UI as prod). Seeded demo uses “[Demo] PLC” titles;
# if that marker is missing, the server clears factory rows for that project and re-seeds (upgrade demos).
# `Factory playground (dev)` + seeded software-factory rows (same UI as production). Requires `pnpm dev` (DEV)
# and a running Nest API. Server allows this only when NODE_ENV !== production (or ALLOW_FACTORY_PLAYGROUND=1).
# VITE_FACTORY_UI_MOCK=true

# Optional override base URL for Plate Copilot.
# Default behavior for company-scoped full editor uses backend route
# `/api/companies/:companyId/ai/copilot` with session cookies (same instance LLM SSOT as chat).
# Set this only when forcing an external copilot provider:
# Copilot requests go to `${VITE_AI_API_URL}/copilot`.
# VITE_AI_API_URL=https://your-api.example.com

# Legacy slim editor (`PlateMarkdownDocumentEditor` / plate-test route) only:
# VITE_PLATE_COMPLETION_API=https://your-openai-compatible-endpoint/v1
